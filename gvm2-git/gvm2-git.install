post_install() {
  echo
  echo "gvm2-git installed. Set up a per-user copy with:"
  echo "  gvm2-setup"
  echo "Then open a new shell (or source ~/.gvm/scripts/gvm) and run:"
  echo "  gvm install go1.22.12"
  echo
  echo "This package conflicts with AUR gvm-git (moovweb/gvm)."
  echo
}

post_upgrade() {
  post_install
}
